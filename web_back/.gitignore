# ==========================================
# 🐍 파이썬 / 백엔드 (FastAPI & ML)
# ==========================================
# 가상환경 (어제 우리가 뱀파이프를 가둬둔 바로 그 방!)
venv/
env/
.venv/

# 파이썬 실행 시 생기는 임시 컴파일 찌꺼기
__pycache__/
*.pyc
*.pyo
*.pyd

# 주피터 노트북 자동 저장 파일
.ipynb_checkpoints/

# ==========================================
# ⚛️ 리액트 / 프론트엔드 (Vite & Node.js)
# ==========================================
# 우주의 블랙홀. 절대 올리면 안 되는 패키지 폴더
node_modules/

# 빌드 결과물 (배포용으로 뭉쳐진 파일들)
dist/
build/
.eslintcache

# ==========================================
# 🔐 보안 / 환경 변수 (가장 중요!!!)
# ==========================================
# API 키, 데이터베이스 비밀번호 등이 들어갈 파일. 절대 깃허브에 올라가면 안 됨!
.env
.env.local
.env.development
.env.test
.env.production

# ==========================================
# 🛠️ 에디터 / OS 자동 생성 파일
# ==========================================
# VSCode 개인 설정
.vscode/

# OS에서 알아서 만드는 쓰레기 파일들
.DS_Store
Thumbs.db